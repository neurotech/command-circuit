{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Command Circuit",
  "version": "0.1.0",
  "identifier": "com.neurotech.command-circuit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Command Circuit",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self",
        "connect-src": "ipc: http://ipc.localhost https://api.github.com https://api.linear.app",
        "font-src": "tauri:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "./desktop-template.desktop"
      }
    }
  }
}
